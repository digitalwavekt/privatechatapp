{
  "name": "pvchat",
  "version": "2.0.0",
  "description": "PVChat - Private Chat Application with Admin Control",
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install && cd ../admin-panel && npm install",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm start",
    "dev:admin": "cd admin-panel && npm start",
    "build:client": "cd client && npm run build",
    "build:admin": "cd admin-panel && npm run build",
    "start:server": "cd server && npm start"
  },
  "keywords": [
    "chat",
    "private",
    "messaging",
    "admin",
    "pvchat"
  ],
  "author": "DigitalWave",
  "license": "MIT",
  "dependencies": {
    "firebase-admin": "^13.9.0",
    "zustand": "^5.0.13"
  }
}
